    user: 'maidang0706',
    repo: 'OPP3',
    token: '',
    filePath: 'data.json',
    commitMsg: 'Update XM方案配置表2026'
};

var filterFields = [
    { id:'filterCustomer', col:'客户', acId:'acCustomer', acListId:'acCustomerList' },
    { id:'filterProjNum', col:'项目号', acId:'acProjNum', acListId:'acProjNumList' },
    { id:'filterProject', col:'项目', acId:'acProject', acListId:'acProjectList' },
    { id:'filterModel', col:'模组下单型号', acId:'acModel', acListId:'acModelList' }
];

var autoSyncTimer = null;

function init() {
    populateAutocomplete();
    initColumnCheckboxes();
    initGitHubSettings();
    applyAllFilters();
}

function getUniqueValues(col) {
    var values = new Set();
    rawData.forEach(function(row) {
        var v = (row[col] || '').toString().trim();
        if (v) values.add(v);
    });
    return Array.from(values).sort();
}

function populateAutocomplete() {
    filterFields.forEach(function(f) { f.allValues = getUniqueValues(f.col); });
}

function onFilterInput(inputId, acId) {
    var input = document.getElementById(inputId);
    var val = input.value.toLowerCase().trim();
    var ff = filterFields.find(function(f) { return f.id === inputId; });
    if (!ff) return;
    var listEl = document.getElementById(ff.acListId);
    listEl.innerHTML = '';
    if (!val) { listEl.classList.remove('show'); return; }
    var matches = ff.allValues.filter(function(v) { return v.toLowerCase().indexOf(val) !== -1; });
    if (matches.length === 0) { listEl.classList.remove('show'); return; }
    matches.slice(0, 20).forEach(function(v) {
        var div = document.createElement('div');
        div.className = 'suggestion-item';
        div.textContent = v;
        div.onmousedown = function(e) {
            e.preventDefault();
            input.value = v;
            listEl.classList.remove('show');
            applyAllFilters();
                    };
        listEl.appendChild(div);
    });
    listEl.classList.add('show');
}

document.addEventListener('click', function(e) {
    filterFields.forEach(function(f) {
        var wrap = document.getElementById(f.acId);
        var list = document.getElementById(f.acListId);
        if (wrap && list && !wrap.contains(e.target)) list.classList.remove('show');
    });
    var dropdown = document.getElementById('columnDropdown');
    var toggle = document.querySelector('.column-toggle');
    if (dropdown && toggle && !toggle.contains(e.target)) dropdown.classList.remove('show');
});

filterFields.forEach(function(f) {
    (function(ff) {
        var input = document.getElementById(ff.id);
        input.addEventListener('keydown', function(e) {
            var list = document.getElementById(ff.acListId);
            if (!list.classList.contains('show')) return;
            var items = list.querySelectorAll('.suggestion-item');
            var activeIdx = -1;
            items.forEach(function(item, i) { if (item.classList.contains('active')) activeIdx = i; });
            if (e.key === 'ArrowDown') {
                e.preventDefault();
                if (activeIdx < items.length - 1) {
                    if (activeIdx >= 0) items[activeIdx].classList.remove('active');
                    items[activeIdx + 1].classList.add('active');
                }
            } else if (e.key === 'ArrowUp') {
                e.preventDefault();
                if (activeIdx > 0) {
                    items[activeIdx].classList.remove('active');
                    items[activeIdx - 1].classList.add('active');
                }
            } else if (e.key === 'Enter') {
                e.preventDefault();
                if (activeIdx >= 0) input.value = items[activeIdx].textContent;
                else if (items.length > 0) input.value = items[0].textContent;
                list.classList.remove('show');
                applyAllFilters();
                            } else if (e.key === 'Escape') { list.classList.remove('show'); }
        });
    })(f);
});

function initColumnCheckboxes() {
    var container = document.getElementById('columnCheckboxes');
    container.innerHTML = '';
    allColumns.forEach(function(col) {
        var label = document.createElement('label');
        var checkbox = document.createElement('input');
        checkbox.type = 'checkbox';
        checkbox.checked = true;
        checkbox.onchange = function() { updateVisibleColumns(); applyAllFilters(); };
        label.appendChild(checkbox);
        label.appendChild(document.createTextNode(col));
        container.appendChild(label);
    });
    updateVisibleColumns();
}

function updateVisibleColumns() {
    var checkboxes = document.querySelectorAll('#columnCheckboxes input[type="checkbox"]');
    visibleColumns = [];
    checkboxes.forEach(function(cb, i) { if (cb.checked) visibleColumns.push(allColumns[i]); });
    document.getElementById('visibleColCount').textContent = visibleColumns.length;
}

function selectAllColumns() {
    document.querySelectorAll('#columnCheckboxes input[type="checkbox"]').forEach(function(cb) { cb.checked = true; });
    updateVisibleColumns(); applyAllFilters(); }

function deselectAllColumns() {
    document.querySelectorAll('#columnCheckboxes input[type="checkbox"]').forEach(function(cb) { cb.checked = false; });
    updateVisibleColumns(); applyAllFilters(); }

function toggleColumnDropdown() { document.getElementById('columnDropdown').classList.toggle('show'); }

function applyAllFilters() {
    var cf = document.getElementById('filterCustomer').value.trim();
    var pn = document.getElementById('filterProjNum').value.trim();
    var pf = document.getElementById('filterProject').value.trim();
    var mf = document.getElementById('filterModel').value.trim();
    var filtered = rawData.filter(function(row) {
        if (cf && (row['客户'] || '').toString().toLowerCase().indexOf(cf.toLowerCase()) === -1) return false;
        if (pn && (row['项目号'] || '').toString().toLowerCase().indexOf(pn.toLowerCase()) === -1) return false;
        if (pf && (row['项目'] || '').toString().toLowerCase().indexOf(pf.toLowerCase()) === -1) return false;
        if (mf && (row['模组下单型号'] || '').toString().toLowerCase().indexOf(mf.toLowerCase()) === -1) return false;
        return true;
    });
    if (currentSortCol) {
        filtered.sort(function(a, b) {
            var va = (a[currentSortCol] || '').toString().trim();
            var vb = (b[currentSortCol] || '').toString().trim();
            var na = parseFloat(va), nb = parseFloat(vb);
            if (!isNaN(na) && !isNaN(nb)) { va = na; vb = nb; }
            if (va < vb) return currentSortDir === 'asc' ? -1 : 1;
            if (va > vb) return currentSortDir === 'asc' ? 1 : -1;
            return 0;
        });
    }
    selectedRowIndex = null;
    renderTable(filtered);
    document.getElementById('totalCount').textContent = rawData.length;
    document.getElementById('filteredCount').textContent = filtered.length;
}

// ==================== 列宽配置 ====================
function getColWidth(col) {
    var widths = {
        '序列': 50, '方案日期': 90, '客户': 55, '项目号': 120, '项目': 70,
        '工程师': 55, '变更时间': 80, '模组总长': 70, '总行程': 65,
        '模组下单型号': 300, '电机型号': 180, '动子个数': 55, '驱动器型号': 200,
        '驱动器功率': 80, '光电开关': 80, '导轨品牌': 60, '读头': 80,
        '动力线': 70, '编码器线': 70, '图纸来源': 60, '刹车电阻': 90, '其他备注': 90
    };
    return widths[col] || 80;
}

function isWrapCol(col) {
    // 长文本列允许换行
    return col === '模组下单型号' || col === '电机型号' || col === '驱动器型号';
}

function renderTable(data) {
    var thead = document.getElementById('tableHead');
    var tbody = document.getElementById('tableBody');

    var headHTML = '<tr>';
    headHTML += '<th class="col-edit" style="width:36px;min-width:36px;">编辑</th>';
    visibleColumns.forEach(function(col) {
        var w = getColWidth(col);
        var sc = (currentSortCol === col) ? ' sorted' : '';
        var si = (currentSortCol === col) ? (currentSortDir === 'asc' ? ' ▲' : ' ▼') : ' ⇅';
        headHTML += '<th class="' + sc + '" style="width:' + w + 'px;min-width:' + w + 'px;" onclick="sortBy(&#39;' + col.replace(/'/g, "&#39;") + '&#39;)">' + col + '<span class="sort-icon">' + si + '</span></th>';
    });
    headHTML += '</tr>';
    thead.innerHTML = headHTML;

    if (data.length === 0) {
        tbody.innerHTML = '<tr><td colspan="' + (visibleColumns.length + 1) + '" class="no-results">没有匹配的记录</td></tr>';
        return;
    }

    window._filteredToRaw = data.map(function(row) { return rawData.indexOf(row); });

    var bodyHTML = '';
    data.forEach(function(row, idx) {
        var selectedClass = (idx === selectedRowIndex) ? ' selected' : '';
        bodyHTML += '<tr class="' + selectedClass + '" onclick="selectRow(' + idx + ', event)">';
        bodyHTML += '<td class="col-edit" onclick="event.stopPropagation();openEditModal(' + idx + ')"><button class="btn-xs" title="编辑此行">✎</button></td>';
        visibleColumns.forEach(function(col) {
            var val = row[col];
            var display = (val === '' || val === null || val === undefined) ? '<span class="empty-cell">-</span>' : escapeHTML(String(val));
            var cellClass = isWrapCol(col) ? ' class="cell-wrap"' : '';
            bodyHTML += '<td' + cellClass + '>' + display + '</td>';
        });
        bodyHTML += '</tr>';
    });
    tbody.innerHTML = bodyHTML;
    window._currentFilteredData = data;
}

function selectRow(idx, event) {
    selectedRowIndex = idx;
    var rows = document.querySelectorAll('#tableBody tr');
    rows.forEach(function(row, i) {
        if (i === idx) { row.classList.add('selected'); row.scrollIntoView({ behavior:'smooth', block:'nearest' }); }
        else row.classList.remove('selected');
    });
}

function sortBy(col) {
    if (currentSortCol === col) currentSortDir = currentSortDir === 'asc' ? 'desc' : 'asc';
    else { currentSortCol = col; currentSortDir = 'asc'; }
    applyAllFilters();
    }

function resetAllFilters() {
    document.getElementById('filterCustomer').value = '';
    document.getElementById('filterProjNum').value = '';
    document.getElementById('filterProject').value = '';
    document.getElementById('filterModel').value = '';
    currentSortCol = null; currentSortDir = 'asc';
    selectedRowIndex = null;
    applyAllFilters();
    }

// ==================== 编辑功能 ====================
function openEditModal(filteredIdx) {
    var rawIdx = window._filteredToRaw[filteredIdx];
    editingRowIdx = rawIdx;
    var row = rawData[rawIdx];
    document.getElementById('editRowLabel').textContent = '(序列: ' + (row['序列'] || '-') + ')';

    var fieldsHTML = '';
    allColumns.forEach(function(col) {
        var val = row[col] || '';
        var isReadonly = (col === '序列');
        var fid = 'edit_' + col.replace(/[^a-zA-Z0-9一-龥]/g, '_');
        fieldsHTML += '<div class="form-row">';
        fieldsHTML += '<label>' + col + '</label>';
        if (col === '其他备注' || col === '模组下单型号') {
            fieldsHTML += '<textarea id="' + fid + '" ' + (isReadonly ? 'readonly' : '') + ' rows="2">' + escapeHTML(String(val)) + '</textarea>';
        } else {
            fieldsHTML += '<input type="text" id="' + fid + '" value="' + escapeHTML(String(val)) + '" ' + (isReadonly ? 'readonly' : '') + '>';
        }
        fieldsHTML += '</div>';
    });
    document.getElementById('editFormFields').innerHTML = fieldsHTML;
    document.getElementById('editModal').classList.add('show');
}

function closeEditModal() {
    document.getElementById('editModal').classList.remove('show');
    editingRowIdx = null;
}

function saveEdit() {
    if (editingRowIdx === null) return;
    var row = rawData[editingRowIdx];
    allColumns.forEach(function(col) {
        if (col === '序列') return;
        var fid = 'edit_' + col.replace(/[^a-zA-Z0-9一-龥]/g, '_');
        var el = document.getElementById(fid);
        if (el) {
            var newVal = el.value || '';
            if (typeof row[col] === 'number' && !isNaN(parseFloat(newVal)) && newVal.trim() !== '') {
                row[col] = parseFloat(newVal);
            } else { row[col] = newVal; }
        }
    });
    closeEditModal();
    populateAutocomplete();
    applyAllFilters();
    updateSyncStatus('unsynced', '未同步');
    showToast('✅ 已保存，请点击「同步到 GitHub」上传', 'success');
}

document.getElementById('editModal').addEventListener('click', function(e) {
    if (e.target === this) closeEditModal();
});

