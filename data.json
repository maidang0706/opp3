async function testGitHubConnection() {
    var user = document.getElementById('ghUser').value.trim();
    var repo = document.getElementById('ghRepo').value.trim();
    var token = document.getElementById('ghToken').value.trim();
    if (!user || !repo || !token) {
        document.getElementById('testResult').innerHTML = '<div style="font-size:11px;padding:6px 10px;border-radius:5px;margin-top:6px;background:#ffebee;color:#c62828;">请填写完整的 GitHub 信息</div>';
        return;
    }
    document.getElementById('testResult').innerHTML = '<div style="font-size:11px;padding:6px 10px;border-radius:5px;margin-top:6px;background:#fff3e0;color:#e65100;">正在测试连接...</div>';
    try {
        var resp = await fetch('https://api.github.com/repos/' + encodeURIComponent(user) + '/' + encodeURIComponent(repo), {
            headers: { 'Authorization': 'token ' + token, 'Accept': 'application/vnd.github.v3+json' }
        });
        if (resp.ok) {
            var rd = await resp.json();
            document.getElementById('testResult').innerHTML = '<div style="font-size:11px;padding:6px 10px;border-radius:5px;margin-top:6px;background:#e8f5e9;color:#2e7d32;">✅ 连接成功！默认分支: <b>' + (rd.default_branch || 'main') + '</b></div>';
        } else {
            var data = await resp.json();
            document.getElementById('testResult').innerHTML = '<div style="font-size:11px;padding:6px 10px;border-radius:5px;margin-top:6px;background:#ffebee;color:#c62828;">❌ 连接失败: ' + (data.message || '未知错误') + '</div>';
        }
    } catch(e) {
        document.getElementById('testResult').innerHTML = '<div style="font-size:11px;padding:6px 10px;border-radius:5px;margin-top:6px;background:#ffebee;color:#c62828;">❌ 网络错误: ' + e.message + '</div>';
    }
}

function updateSyncStatus(status, text) {
    var dot = document.getElementById('syncDot');
    var txt = document.getElementById('syncText');
    var statusEl = document.getElementById('syncStatus');
    dot.className = 'sync-dot ' + status;
    statusEl.className = 'sync-status ' + status;
    txt.textContent = text || (status === 'idle' ? '已同步' : status === 'syncing' ? '同步中...' : '同步失败');
}

var isSyncing = false;

function showSyncError(msg) {
    updateSyncStatus('error', '同步失败');
    var el = document.getElementById('syncDetail');
    if (el) { el.style.display = 'block'; el.textContent = '⚠ 同步失败：' + msg; }
    showToast('❌ 同步失败：' + msg, 'error', 9000);
    console.error('Sync error:', msg);
}

function clearSyncError() {
    var el = document.getElementById('syncDetail');
    if (el) { el.style.display = 'none'; el.textContent = ''; }
}

async function syncToGitHub() {
    if (isSyncing) { showToast('同步进行中，请稍候...', 'info'); return; }
    var settings = JSON.parse(localStorage.getItem('xm_github_settings') || 'null');
    if (!settings || !settings.user || !settings.repo || !settings.token) {
        updateSyncStatus('error', '未配置');
        showToast('请先点击「设置」填写 GitHub 账号信息', 'error');
        return;
    }
    isSyncing = true;
    updateSyncStatus('syncing', '同步中...');
    showToast('正在同步到 GitHub...', 'info');
    clearSyncError();
    try {
        var apiBase = 'https://api.github.com/repos/' + encodeURIComponent(settings.user) + '/' + encodeURIComponent(settings.repo);
        var fileUrl = apiBase + '/contents/' + encodeURIComponent(settings.filePath);
        var headers = { 'Authorization': 'token ' + settings.token, 'Accept': 'application/vnd.github.v3+json' };

        // 1) 校验仓库是否存在，并读取真实默认分支（兼容 master / main）
        var repoResp = await fetch(apiBase, { headers: headers });
        if (!repoResp.ok) {
            var repoErr = await repoResp.json().catch(function(){ return {}; });
            var rmsg = repoErr.message || ('HTTP ' + repoResp.status);
            if (repoResp.status === 404) rmsg = '仓库不存在（检查用户名 / 仓库名）';
            else if (repoResp.status === 401) rmsg = 'Token 无效或已过期';
            else if (repoResp.status === 403) rmsg = '无仓库访问权限，确认 Token 具备 repo 权限';
            showSyncError(rmsg);
            isSyncing = false;
            return;
        }
        var repoData = await repoResp.json();
        var branch = repoData.default_branch || 'main';

        // 2) 取文件现有 SHA（用于更新已有文件）
        var sha = null;
        try {
            var getResp = await fetch(fileUrl + '?ref=' + encodeURIComponent(branch), { headers: headers });
            if (getResp.ok) { var getData = await getResp.json(); sha = getData.sha; }
        } catch(e) {}

        var htmlContent = document.documentElement.outerHTML;
        // 推送前脱敏：删除 HTML 中的 Token 字符串，避免 GitHub Secret 扫描拦截
        if (settings.token) {
            htmlContent = htmlContent.split(settings.token).join('');
        }
        var base64Content = btoa(unescape(encodeURIComponent(htmlContent)));
        var body = { message: settings.commitMsg || 'Update', content: base64Content, branch: branch };
        if (sha) body.sha = sha;

        var putResp = await fetch(fileUrl, { method: 'PUT', headers: headers, body: JSON.stringify(body) });
        // 若因缺少 SHA 被拒（文件已存在），重新取 SHA 后重试一次
        if (!putResp.ok && putResp.status === 422 && !sha) {
            try {
                var reGet = await fetch(fileUrl + '?ref=' + encodeURIComponent(branch), { headers: headers });
                if (reGet.ok) { var reData = await reGet.json(); sha = reData.sha; body.sha = sha; }
            } catch(e) {}
            if (sha) putResp = await fetch(fileUrl, { method: 'PUT', headers: headers, body: JSON.stringify(body) });
        }

        if (putResp.ok) {
            updateSyncStatus('idle', '已同步');
            clearSyncError();
            showToast('✅ 已同步到 ' + settings.repo + ' / ' + settings.filePath, 'success');
        } else {
            var errData = await putResp.json().catch(function(){ return {}; });
            var emsg = errData.message || ('HTTP ' + putResp.status);
            if (putResp.status === 403) emsg = '无写入权限：Token 需具备 repo 权限（或细粒度 Token 需 contents:write）';
            else if (putResp.status === 422) emsg = '提交被拒：' + (errData.message || '未知原因');
            else if (putResp.status === 404) emsg = '接口路径错误（仓库 / 分支 / 文件名）';
            showSyncError(emsg);
        }
    } catch(e) {
        showSyncError('网络错误：' + (e && e.message ? e.message : e));
    }
    isSyncing = false;
}

// ==================== 从GitHub下载 ====================
function extractRawData(html) {
    var idx = html.indexOf('var rawData = ');
    if (idx < 0) return null;
    var start = html.indexOf('[', idx);
    if (start < 0) return null;
    var depth = 0, inStr = false, esc = false;
    for (var i = start; i < html.length; i++) {
        var ch = html[i];
        if (inStr) {
            if (esc) esc = false;
            else if (ch.charCodeAt(0) === 92) esc = true;
            else if (ch === '"') inStr = false;
        } else {
            if (ch === '"') inStr = true;
            else if (ch === '[') depth++;
            else if (ch === ']') { depth--; if (depth === 0) { try { return JSON.parse(html.slice(start, i + 1)); } catch(e) { return null; } } }
        }
    }
    return null;
}

async function downloadFromGitHub() {
    var settings = JSON.parse(localStorage.getItem('xm_github_settings') || 'null');
    if (!settings || !settings.user || !settings.repo || !settings.token) {
        showToast('请先点击「设置」填写 GitHub 账号信息', 'error');
        return;
    }
    updateSyncStatus('syncing', '下载中...');
    showToast('正在从 GitHub 下载...', 'info');
    clearSyncError();
    try {
        var apiBase = 'https://api.github.com/repos/' + encodeURIComponent(settings.user) + '/' + encodeURIComponent(settings.repo);
        var fileUrl = apiBase + '/contents/' + encodeURIComponent(settings.filePath);
        var headers = { 'Authorization': 'token ' + settings.token, 'Accept': 'application/vnd.github.v3+json' };
        var repoResp = await fetch(apiBase, { headers: headers });
        if (!repoResp.ok) { showSyncError('仓库访问失败：HTTP ' + repoResp.status); return; }
        var repoData = await repoResp.json();
        var branch = repoData.default_branch || 'main';
        var resp = await fetch(fileUrl + '?ref=' + encodeURIComponent(branch), { headers: headers });
        if (!resp.ok) { showSyncError('文件不存在：' + settings.filePath); return; }
        var j = await resp.json();
        var content = decodeURIComponent(escape(atob(j.content)));
        var newData = extractRawData(content);
        if (!newData || !newData.length) { showSyncError('未能从文件中解析出数据'); return; }
        // 列对齐：若下载数据的字段与当前不一致，则重建列配置
        if (newData[0] && Object.keys(newData[0]).join('|') !== allColumns.join('|')) {
            allColumns = Object.keys(newData[0]);
            visibleColumns = allColumns.slice();
            initColumnCheckboxes();
        }
        rawData = newData;
        populateAutocomplete();
        applyAllFilters();
        updateSyncStatus('idle', '已下载');
        showToast('✅ 已从 GitHub 下载 ' + newData.length + ' 条记录', 'success');
    } catch(e) {
        showSyncError('下载失败：' + (e && e.message ? e.message : e));
    }
}

// ==================== Excel导出 ====================
function exportToExcel() {
    var cf = document.getElementById('filterCustomer').value.trim();
    var pn = document.getElementById('filterProjNum').value.trim();
    var pf = document.getElementById('filterProject').value.trim();
    var mf = document.getElementById('filterModel').value.trim();
    var filtered = rawData.filter(function(row) {
        if (cf && (row['客户'] || '').toString().toLowerCase().indexOf(cf.toLowerCase()) === -1) return false;
        if (pn && (row['项目号'] || '').toString().toLowerCase().indexOf(pn.toLowerCase()) === -1) return false;
        if (pf && (row['项目'] || '').toString().toLowerCase().indexOf(pf.toLowerCase()) === -1) return false;
        if (mf && (row['模组下单型号'] || '').toString().toLowerCase().indexOf(mf.toLowerCase()) === -1) return false;
        return true;
    });
    var xml = '<?xml version="1.0" encoding="UTF-8"?>\n';
    xml += '<?mso-application progid="Excel.Sheet"?>\n';
    xml += '<Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet" xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet">\n';
    xml += '<Worksheet ss:Name="Sheet1"><Table>\n';
    xml += '<Row>';
    visibleColumns.forEach(function(col) { xml += '<Cell><Data ss:Type="String">' + escapeXML(col) + '</Data></Cell>'; });
    xml += '</Row>\n';
    filtered.forEach(function(row) {
        xml += '<Row>';
        visibleColumns.forEach(function(col) {
            var val = row[col];
            if (val === '' || val === null || val === undefined) xml += '<Cell><Data ss:Type="String"></Data></Cell>';
            else if (typeof val === 'number') xml += '<Cell><Data ss:Type="Number">' + val + '</Data></Cell>';
            else xml += '<Cell><Data ss:Type="String">' + escapeXML(String(val)) + '</Data></Cell>';
        });
        xml += '</Row>\n';
    });
    xml += '</Table></Worksheet></Workbook>';
    var blob = new Blob([xml], { type: 'application/vnd.ms-excel;charset=utf-8;' });
    var url = URL.createObjectURL(blob);
    var a = document.createElement('a');
    a.href = url; a.download = 'XM方案配置表2026_' + new Date().toISOString().slice(0,10) + '.xls';
    document.body.appendChild(a); a.click(); document.body.removeChild(a);
    URL.revokeObjectURL(url);
    showToast('✅ Excel已下载，共 ' + filtered.length + ' 条记录', 'success');
}

function escapeXML(str) {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&apos;');
}

function showToast(msg, type, duration) {
    var toast = document.getElementById('toast');
    toast.textContent = msg;
    toast.className = 'toast ' + (type || 'info') + ' show';
    clearTimeout(toast._timeout);
    toast._timeout = setTimeout(function() { toast.classList.remove('show'); }, duration || 3000);
}

function escapeHTML(str) {
    var div = document.createElement('div');
    div.appendChild(document.createTextNode(str));
    return div.innerHTML;
}

document.getElementById('settingsModal').addEventListener('click', function(e) {
    if (e.target === this) closeSettings();
});

init();
</script>

</body></html>