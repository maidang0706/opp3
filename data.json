var allColumns = ["序列", "方案日期", "客户", "项目号", "项目", "工程师", "变更时间", "模组总长", "总行程", "模组下单型号", "电机型号", "动子个数", "驱动器型号", "驱动器功率", "光电开关", "导轨品牌", "读头", "动力线", "编码器线", "图纸来源", "刹车电阻", "其他备注"];
